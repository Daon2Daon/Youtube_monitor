# ─────────────────────────────────────────────────────────────────
# YouTube Monitor 환경 변수 예시
# 이 파일을 .env로 복사 후 실제 값으로 교체하세요.
# ─────────────────────────────────────────────────────────────────

# ─── SQLite 데이터베이스 경로 (DATABASE_URL) ─────────────────────────────────
# 앱이 사용하는 DB 파일 위치는 이 값 하나로 결정됩니다.
# 형식: sqlite:///경로/파일명.db
#
# [기본] 프로젝트(또는 컨테이너 /app) 기준 상대 경로
#   - 로컬 실행: youtube_monitor/data/youtube_monitor.db
#   - Docker: 컨테이너 내부 /app/data/youtube_monitor.db
DATABASE_URL=sqlite:///./data/youtube_monitor.db
#
# [Docker] 호스트의 다른 경로에 저장 (예: Synology /volume1/youtube/db)
#   1) DATABASE_URL은 컨테이너 안 경로를 유지 (아래 기본값 그대로 권장)
#   2) docker-compose.yml / docker-compose.local.yml 의 volumes 를 수정:
#        volumes:
#          - /volume1/youtube/db:/app/data
#   → 실제 DB 파일: /volume1/youtube/db/youtube_monitor.db
#   (호스트 폴더를 미리 만들고 Docker가 쓸 수 있는 권한을 부여하세요)
#
# [직접 실행] 호스트 절대 경로 (Linux/macOS — 슬래시 4개)
# DATABASE_URL=sqlite:////volume1/youtube/db/youtube_monitor.db
#
# [직접 실행] Windows 절대 경로 예시
# DATABASE_URL=sqlite:///C:/data/youtube/youtube_monitor.db
#
# 참고: 경로 변경 후 앱(컨테이너) 재시작 필요. 기존 DB는 파일을 새 경로로 복사하세요.

# 디버그 모드 (프로덕션에서는 false)
DEBUG=false

# 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# 세션 보안 키 (랜덤 32바이트 이상 문자열)
SESSION_SECRET_KEY=your_very_long_random_secret_key_here
SESSION_MAX_AGE=86400

# Telegram 봇 토큰
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 설정값 암호화 키 (Fernet 키, 미설정 시 평문 저장)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
YOUTUBE_SETTINGS_FERNET_KEY=

# ─── 부트스트랩 설정 (최초 실행 시 DB에 자동 등록) ───────────────────────────
# 이미 DB에 값이 있으면 덮어쓰지 않습니다.

# litellm AI Gateway
YOUTUBE_BOOTSTRAP_LITELLM_BASE_URL=http://litellm:4000
YOUTUBE_BOOTSTRAP_LITELLM_API_KEY=

# 기본 분석 모델
YOUTUBE_BOOTSTRAP_PRIMARY_MODEL=gemini/gemini-3.1-flash-lite
YOUTUBE_BOOTSTRAP_FALLBACK_MODEL=gemini/gemini-2.5-flash-lite
YOUTUBE_BOOTSTRAP_TAGGING_MODEL=gemini/gemini-3.1-flash-lite

# YouTube Data API 키
YOUTUBE_BOOTSTRAP_YOUTUBE_API_KEY=

# GHCR 이미지 배포용
GITHUB_USERNAME=your_github_username
